# HTML — never cache, always revalidate
/*.html
  Cache-Control: public, max-age=0, must-revalidate

/index.html
  Cache-Control: public, max-age=0, must-revalidate

# Hashed JS/CSS assets — immutable long cache
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

# Images in /public — always revalidate so replaced files update immediately.
# (Hashed images bundled into /assets/* are still immutable via the rule above.)
/*.png
  Cache-Control: public, max-age=0, must-revalidate

/*.jpg
  Cache-Control: public, max-age=0, must-revalidate

/*.jpeg
  Cache-Control: public, max-age=0, must-revalidate

/*.webp
  Cache-Control: public, max-age=0, must-revalidate

/*.svg
  Cache-Control: public, max-age=0, must-revalidate

/*.ico
  Cache-Control: public, max-age=0, must-revalidate

# Static files
/sitemap.xml
  Content-Type: application/xml; charset=utf-8
  X-Content-Type-Options: nosniff
  Cache-Control: public, max-age=3600

/robots.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=3600
